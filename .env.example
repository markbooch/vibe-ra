# Copy to .env and fill in values. .env is gitignored.

# --- Required: Gemini API key for the LLM brain ---
GEMINI_API_KEY=

# Model used for both the voice translator and the adviser.
GEMINI_MODEL=gemini-2.0-flash-exp

# --- OpenRA ExternalControl socket ---
# vibera defaults to 7778 to match patches/openra-port.patch. If you keep
# the upstream OpenRA default, set OPENRA_PORT=7777 here.
OPENRA_HOST=127.0.0.1
OPENRA_PORT=7778

# --- Voice (whisper.cpp via pywhispercpp) ---
# Model size: tiny | base | small | medium | large-v3
# small is the recommended default on Apple Silicon (Metal-backed,
# ~465 MB, sub-second transcription for short utterances).
VIBERA_VOICE_MODEL=small

# Spoken language. Use BCP-47 codes (en, zh, ja, de, ...) or "auto" for
# whisper auto-detect. Default is English.
VIBERA_VOICE_LANG=en

# Silence detection threshold (RMS, 0.0-1.0). Lower = more sensitive.
VIBERA_VOICE_SILENCE_RMS=0.0025

# --- State directory (task history, etc.) ---
# Defaults to ~/.vibera
# VIBERA_STATE_DIR=

# --- Debug ---
# Set to 1 for verbose logging.
VIBERA_DEBUG=0
